digraph "triangle"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  Node1 [label="triangle",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black",tooltip="Represents a triangle geometry, its three vertices and its material."];
  Node2 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" a\nb\nc" ,fontname="Helvetica"];
  Node2 [label="vertex",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classvertex.html",tooltip="Represents a vertex of a triangle."];
  Node3 -> Node2 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" uv" ,fontname="Helvetica"];
  Node3 [label="vec2",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structvec2.html",tooltip="Represents a 2-dimensional vector."];
  Node4 -> Node2 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" normal\nposition" ,fontname="Helvetica"];
  Node4 [label="vec3",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structvec3.html",tooltip="Represents a 3-dimensional vector."];
}
