  Node2 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" material" ,fontname="Helvetica"];
  Node2 [label="gpu_Material",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classgpu__Material.html",tooltip="GPU compatible Material class."];
  Node3 -> Node2 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" normal_map\ntexture" ,fontname="Helvetica"];
  Node3 [label="gpu_Texture",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classgpu__Texture.html",tooltip="GPU compatible Texture class."];
  Node4 -> Node2 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" brdf" ,fontname="Helvetica"];
  Node4 [label="gpu_BRDF",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classgpu__BRDF.html",tooltip="GPU compatible BRDF class."];
  Node5 -> Node2 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" ambient\ndiffuse\nemissive\nspecular\ntransmittance" ,fontname="Helvetica"];
  Node5 [label="gpu_vec3",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgpu__vec3.html",tooltip="GPU compatible vec3 struct."];
  Node6 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" a\nb\nc" ,fontname="Helvetica"];
  Node6 [label="gpu_vertex",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classgpu__vertex.html",tooltip="GPU compatible vertex class."];
  Node7 -> Node6 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" uv" ,fontname="Helvetica"];
  Node7 [label="gpu_vec2",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgpu__vec2.html",tooltip="GPU compatible vec2 struct."];
  Node5 -> Node6 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" normal\nposition" ,fontname="Helvetica"];
